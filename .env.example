# Confluence Authentication
# Copy this file to .env and fill in your values

CONFLUENCE_BASE_URL=https://appliedintuition.atlassian.net/wiki
CONFLUENCE_EMAIL=you@appliedintuition.com
CONFLUENCE_API_TOKEN=your_api_token_here

# CONFLUENCE values
CONFLUENCE_DEFAULT_PARENT_PAGE_ID=
CONFLUENCE_DEFAULT_SPACE_KEY=

# Template Page ID (page to copy content from when creating new pages)
CONFLUENCE_DEFAULT_TEMPLATE_PAGE_ID=2535784694